<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="15.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.alunostm.controller.AlunoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <Label text="Sistema de Gestão de Alunos">
        <font>
            <Font name="System Bold" size="18.0"/>
        </font>
    </Label>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Filtrar:"/>
        <ComboBox fx:id="comboOrdenacao" prefWidth="300.0" promptText="Selecione o filtro de ordenação..."/>
        <Button mnemonicParsing="false" onAction="#tratarBotaoGerar" prefWidth="120.0"
                style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Listar"/>
    </HBox>

    <TableView fx:id="tabelaAlunos" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn sortable="false" fx:id="colNome" prefWidth="250.0" text="Nome"/>
            <TableColumn sortable="false" fx:id="colCurso" prefWidth="200.0" text="Curso"/>
            <TableColumn sortable="false" fx:id="colEnfase" prefWidth="150.0" text="Ênfase"/>
            <TableColumn sortable="false" fx:id="colSituacao" prefWidth="100.0" text="Situação"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>